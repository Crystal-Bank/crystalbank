        <!-- API Keys Projection -->
        <mxCell id="apikeys-projection" value="API Keys Projection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
