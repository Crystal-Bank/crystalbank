        <!-- Customer linked to Account -->
        <mxCell id="dep-cust-acc" value="customer_ids" style="endArrow=open;endFill=0;dashed=1;strokeColor=#82b366;fontColor=#82b366;fontSize=9;" edge="1" parent="1" source="customers-projection" target="accounts-api">
