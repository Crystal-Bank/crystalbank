        <mxCell id="dep-acc-tx" value="account IDs" style="endArrow=open;endFill=0;dashed=1;strokeColor=#82b366;fontColor=#82b366;fontSize=9;" edge="1" parent="1" source="accounts-projection" target="tx-api">
