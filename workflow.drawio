        <!-- Event Store label -->
        <mxCell id="eventstore" value="Event Store (PostgreSQL)&#xa;All events persisted here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="640" width="300" height="50" as="geometry" />
