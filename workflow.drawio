        <mxCell id="dep-roles-users" value="role_ids" style="endArrow=open;endFill=0;dashed=1;strokeColor=#82b366;fontColor=#82b366;fontSize=9;" edge="1" parent="1" source="roles-projection" target="users-assign-api">
