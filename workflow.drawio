        <!-- Scope required for Customers -->
        <mxCell id="dep-scope-customers" value="scope_id required" style="endArrow=open;endFill=0;dashed=1;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=9;" edge="1" parent="1" source="scope-projection" target="customers-api">
