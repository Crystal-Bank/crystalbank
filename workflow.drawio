        <!-- User required for API Keys -->
        <mxCell id="dep-users-apikeys" value="user_id" style="endArrow=open;endFill=0;dashed=1;strokeColor=#82b366;fontColor=#82b366;fontSize=9;" edge="1" parent="1" source="users-projection" target="apikeys-gen-api">
